terraform {
  required_version = ">= 1.9.0"

  required_providers {
    azurerm = {
      source  = "hashicorp/azurerm"
      version = "~> 4.74"
    }
    azapi = {
      source  = "azure/azapi"
      version = "~> 2.0"
    }
    random = {
      source  = "hashicorp/random"
      version = "~> 3.6"
    }
  }
}

provider "azurerm" {
  features {}
  # Pinned explicitly so the provider never falls back to an ambient CLI default.
  subscription_id = var.subscription_id
}

provider "azapi" {
  subscription_id = var.subscription_id
}
